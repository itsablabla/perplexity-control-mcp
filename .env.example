# Required: Your Perplexity API key
# Get one at https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=pplx-your-key-here

# Transport: "stdio" (default, for Claude Desktop / Cursor / Comet)
#            "http"  (for remote/network access via Streamable HTTP)
MCP_TRANSPORT=stdio

# HTTP port (only used when MCP_TRANSPORT=http)
MCP_PORT=3001
